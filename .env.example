# === Project ===
PROJECT_NAME=Invext

# === Database (async PostgreSQL URL for SQLAlchemy/asyncpg) ===
# Формат: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/invext

# === Backend / App ===
# Хост и порт, на которых слушает FastAPI внутри контейнера
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Секретный ключ для проверки админов при вызовах legacy-API из бота
ADMIN_API_KEY=super-secret-key

# === Telegram Bot ===
# Токен бота от @BotFather
BOT_TOKEN=your-telegram-bot-token
# URL бэкенда для запросов из бота (в Docker-сети: http://app:8000)
BACKEND_BASE_URL=http://app:8000

# === Admin (бот + HTML-dashboard /database) ===
# Telegram ID админов через запятую (только они видят /admin в боте и могут подтверждать заявки)
ADMIN_TELEGRAM_IDS=123456789,987654321
# Секрет для подписи JWT-сессий админ-дэшборда (/database)
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
# (Опционально) список IP через запятую, которым разрешён доступ к /database/api/*
# Например: ADMIN_ALLOWED_IPS=1.2.3.4,5.6.7.8  ; если пусто — без ограничения по IP
ADMIN_ALLOWED_IPS=

# === Лимиты (опционально) ===
# Минимальные/максимальные суммы пополнения и вывода (в USDT)
MIN_DEPOSIT=1
MAX_DEPOSIT=100000
MIN_WITHDRAW=1
MAX_WITHDRAW=100000

# === Crypto Pay (invoice-based deposits) ===
# API-токен приложения в @CryptoBot / @CryptoTestnetBot
CRYPTO_PAY_TOKEN=your-crypto-pay-token
# Публичный URL backend (для webhook), например https://your-domain.com
APP_URL=https://your-domain.com

# === Project ===
PROJECT_NAME=Invext

# === Database (async PostgreSQL URL for SQLAlchemy/asyncpg) ===
# Формат: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/invext

# === Backend / App ===
# Хост и порт, на которых слушает FastAPI внутри контейнера
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Секретный ключ для проверки админов при вызовах legacy-API из бота
ADMIN_API_KEY=super-secret-key

# === Telegram Bot ===
# Токен бота от @BotFather
BOT_TOKEN=your-telegram-bot-token
# URL бэкенда для запросов из бота (в Docker-сети: http://app:8000)
BACKEND_BASE_URL=http://app:8000

# === Admin (бот + HTML-dashboard /database) ===
# Telegram ID админов через запятую (только они видят /admin в боте и могут подтверждать заявки)
ADMIN_TELEGRAM_IDS=123456789,987654321
# Секрет для подписи JWT-сессий админ-дэшборда (/database)
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
# (Опционально) список IP через запятую, которым разрешён доступ к /database/api/*
# Например: ADMIN_ALLOWED_IPS=1.2.3.4,5.6.7.8  ; если пусто — без ограничения по IP
ADMIN_ALLOWED_IPS=

# === Лимиты (опционально) ===
# Минимальные/максимальные суммы пополнения и вывода (в USDT)
MIN_DEPOSIT=1
MAX_DEPOSIT=100000
MIN_WITHDRAW=1
MAX_WITHDRAW=100000

# === Публичный URL backend (для webhook и редиректов) ===
APP_URL=https://your-domain.com

# === NOWPayments (пополнение USDT BEP20) ===
# API Key из личного кабинета NOWPayments
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
# IPN Secret из Payment Settings → IPN (для проверки подписи webhook)
NOWPAYMENTS_IPN_SECRET=your-ipn-secret
# Базовый URL API (production: https://api.nowpayments.io , sandbox: https://api-sandbox.nowpayments.io)
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io
# URL, на который NOWPayments отправляет IPN (должен быть доступен извне). Обычно: ${APP_URL}/v1/payments/webhook/nowpayments
NOWPAYMENTS_CALLBACK_URL=https://your-domain.com/v1/payments/webhook/nowpayments
# Куда перенаправить пользователя после успешной/отменённой оплаты (опционально)
NOWPAYMENTS_SUCCESS_URL=https://your-domain.com/success
NOWPAYMENTS_CANCEL_URL=https://your-domain.com/cancel
# Валюта оплаты: usdtbsc = USDT в сети BEP20 (BSC)
# DEFAULT_PAY_CURRENCY=usdtbsc
# DEFAULT_PAY_NETWORK=BSC

# (Устарело) Crypto Pay — больше не используется; оставлено для совместимости .env
# CRYPTO_PAY_TOKEN=
